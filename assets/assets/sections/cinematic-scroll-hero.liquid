{% comment %}
  Cinematic Scroll Hero Section
  Version: 1.0.0
  Description: A premium cinematic scroll animation hero with GSAP and ScrollTrigger
  Author: Open Source Contributors
  License: MIT
{% endcomment %}

{{ 'cinematic-scroll-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_id = section.id
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign overlay_gradient = section.settings.overlay_gradient
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign border_radius = section.settings.border_radius
  assign image_width = section.settings.image_width
  assign layer_opacity = section.settings.layer_opacity | divided_by: 100.0
  assign desktop_spacing_top = section.settings.desktop_spacing_top
  assign desktop_spacing_bottom = section.settings.desktop_spacing_bottom
  assign mobile_spacing_top = section.settings.mobile_spacing_top
  assign mobile_spacing_bottom = section.settings.mobile_spacing_bottom
  assign section_height = section.settings.section_height
  assign max_content_width = section.settings.max_content_width
  assign content_alignment = section.settings.content_alignment
  assign animation_enabled = section.settings.animation_enabled
  assign scroll_speed = section.settings.scroll_speed
  assign floating_enabled = section.settings.floating_enabled
  assign floating_intensity = section.settings.floating_intensity
  assign rotation_amount = section.settings.rotation_amount
  assign parallax_intensity = section.settings.parallax_intensity
  assign layer_spread = section.settings.layer_spread
  assign blur_amount = section.settings.blur_amount
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign rich_text = section.settings.rich_text
  assign primary_cta_label = section.settings.primary_cta_label
  assign primary_cta_url = section.settings.primary_cta_url
  assign secondary_cta_label = section.settings.secondary_cta_label
  assign secondary_cta_url = section.settings.secondary_cta_url
  assign show_cards = section.settings.show_cards
  assign card_collection_1 = section.settings.card_collection_1
  assign card_collection_2 = section.settings.card_collection_2
  assign card_product_1 = section.settings.card_product_1
  assign card_product_2 = section.settings.card_product_2
  assign image_aspect_ratio = section.settings.image_aspect_ratio
  assign image_object_fit = section.settings.image_object_fit
  assign image_drop_shadow = section.settings.image_drop_shadow
  assign image_lazy_loading = section.settings.image_lazy_loading
  assign image_widths = section.settings.image_widths
-%}

{%- style -%}
  #cinematic-{{ section_id }} {
    --cinematic-bg-color: {{ bg_color }};
    --cinematic-text-color: {{ text_color }};
    --cinematic-overlay-opacity: {{ overlay_opacity }};
    --cinematic-border-radius: {{ border_radius }}px;
    --cinematic-image-width: {{ image_width }}%;
    --cinematic-layer-opacity: {{ layer_opacity }};
    --cinematic-desktop-spacing-top: {{ desktop_spacing_top }}px;
    --cinematic-desktop-spacing-bottom: {{ desktop_spacing_bottom }}px;
    --cinematic-mobile-spacing-top: {{ mobile_spacing_top }}px;
    --cinematic-mobile-spacing-bottom: {{ mobile_spacing_bottom }}px;
    --cinematic-section-height: {{ section_height }}vh;
    --cinematic-max-content-width: {{ max_content_width }}px;
    --cinematic-scroll-speed: {{ scroll_speed }};
    --cinematic-floating-intensity: {{ floating_intensity }};
    --cinematic-rotation-amount: {{ rotation_amount }};
    --cinematic-parallax-intensity: {{ parallax_intensity }};
    --cinematic-layer-spread: {{ layer_spread }};
    --cinematic-blur-amount: {{ blur_amount }}px;
    --cinematic-image-aspect-ratio: {{ image_aspect_ratio }};
    --cinematic-image-object-fit: {{ image_object_fit }};
    {% if image_drop_shadow %}
      --cinematic-image-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    {% else %}
      --cinematic-image-shadow: none;
    {% endif %}
  }

  {% if overlay_gradient != blank %}
    #cinematic-{{ section_id }} .cinematic__overlay {
      background: {{ overlay_gradient }};
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    #cinematic-{{ section_id }} {
      --cinematic-section-height: {{ section_height | minus: 20 }}vh;
    }
  }
{%- endstyle -%}

<div
  class="cinematic"
  id="cinematic-{{ section_id }}"
  data-section-id="{{ section_id }}"
  data-animation-enabled="{{ animation_enabled }}"
  data-floating-enabled="{{ floating_enabled }}"
  data-content-alignment="{{ content_alignment }}"
  role="region"
  aria-label="{{ heading | default: 'Featured content' | escape }}"
>
  <div class="cinematic__container">
    <div class="cinematic__layers" aria-hidden="true">
      {%- for i in (1..4) -%}
        {%- liquid
          assign image_key = 'image_' | append: i
          assign image = section.settings[image_key]
          assign start_position_key = 'start_position_' | append: i
          assign start_position = section.settings[start_position_key]
          assign direction_key = 'direction_' | append: i
          assign direction = section.settings[direction_key]
        -%}
        {%- if image != blank -%}
          <div
            class="cinematic__layer cinematic__layer--{{ i }}"
            data-layer="{{ i }}"
            data-start-position="{{ start_position }}"
            data-direction="{{ direction }}"
            style="z-index: {{ 10 | minus: i }};"
          >
            {{
              image
              | image_url: width: 1500
              | image_tag:
                widths: image_widths,
                sizes: '(min-width: 1440px) 1200px, (min-width: 750px) calc(100vw - 2rem), 100vw',
                loading: image_lazy_loading,
                fetchpriority: 'high',
                class: 'cinematic__image',
                alt: image.alt | default: heading | escape,
                draggable: 'false'
            }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {% if overlay_gradient != blank or overlay_opacity > 0 %}
      <div class="cinematic__overlay" aria-hidden="true"></div>
    {% endif %}

    <div class="cinematic__content cinematic__content--{{ content_alignment }}">
      {%- if heading != blank -%}
        <h1 class="cinematic__heading">{{ heading | escape }}</h1>
      {%- endif -%}

      {%- if subheading != blank -%}
        <p class="cinematic__subheading">{{ subheading | escape }}</p>
      {%- endif -%}

      {%- if rich_text != blank -%}
        <div class="cinematic__rich-text rte">
          {{ rich_text }}
        </div>
      {%- endif -%}

      {%- if primary_cta_label != blank or secondary_cta_label != blank -%}
        <div class="cinematic__ctas">
          {%- if primary_cta_label != blank -%}
            <a
              href="{{ primary_cta_url | default: '#' }}"
              class="cinematic__cta cinematic__cta--primary"
              {% if primary_cta_url == blank %}tabindex="-1" aria-disabled="true"{% endif %}
            >
              {{ primary_cta_label | escape }}
            </a>
          {%- endif -%}

          {%- if secondary_cta_label != blank -%}
            <a
              href="{{ secondary_cta_url | default: '#' }}"
              class="cinematic__cta cinematic__cta--secondary"
              {% if secondary_cta_url == blank %}tabindex="-1" aria-disabled="true"{% endif %}
            >
              {{ secondary_cta_label | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_cards -%}
        <div class="cinematic__cards">
          {%- if card_product_1 != blank -%}
            <div class="cinematic__card cinematic__card--product">
              {%- render 'card-product',
                card_product: card_product_1,
                media_aspect_ratio: 'adapt',
                show_secondary_image: false,
                show_vendor: false,
                show_rating: false,
                lazy_load: true
              -%}
            </div>
          {%- endif -%}

          {%- if card_product_2 != blank -%}
            <div class="cinematic__card cinematic__card--product">
              {%- render 'card-product',
                card_product: card_product_2,
                media_aspect_ratio: 'adapt',
                show_secondary_image: false,
                show_vendor: false,
                show_rating: false,
                lazy_load: true
              -%}
            </div>
          {%- endif -%}

          {%- if card_collection_1 != blank -%}
            <div class="cinematic__card cinematic__card--collection">
              {%- render 'card-collection',
                card_collection: card_collection_1,
                media_aspect_ratio: 'adapt',
                columns: 1
              -%}
            </div>
          {%- endif -%}

          {%- if card_collection_2 != blank -%}
            <div class="cinematic__card cinematic__card--collection">
              {%- render 'card-collection',
                card_collection: card_collection_2,
                media_aspect_ratio: 'adapt',
                columns: 1
              -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if animation_enabled -%}
      <button
        class="cinematic__scroll-indicator"
        aria-label="{{ 'accessibility.scroll_down' | t }}"
        type="button"
        onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})"
      >
        <span class="cinematic__scroll-indicator-line"></span>
      </button>
    {%- endif -%}
  </div>
</div>

<script src="{{ 'cinematic-scroll-hero.js' | asset_url }}" defer="defer"></script>

